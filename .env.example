# Copia este archivo a .env y completa con tus credenciales reales.
# Nunca commitees .env (ya está en .gitignore).

# Cadena de conexión PostgreSQL para Prisma.
# Formato: postgresql://usuario:contraseña@host:puerto/base_de_datos?schema=public
DATABASE_URL="postgresql://user:password@localhost:5432/hechos?schema=public"
