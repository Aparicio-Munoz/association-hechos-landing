# Copia este archivo a .env.local y completa según tu entorno.
# Nunca commitees .env* reales (ya están en .gitignore).

# URL del backend real (NestJS) — usado por las rutas /api/auth/* para
# registro, login, refresh y logout de sesión.
BACKEND_URL="http://localhost:3001"

# Flag temporal (ver src/lib/feature-flags.ts): mientras BACKEND_URL no
# apunte a un backend público, deja esto en "false" para que
# /registro, /login y /cuenta muestren "próximamente" en vez de fallar.
# Poner "true" en local si tienes el backend corriendo, y en Vercel el
# día que el backend quede desplegado.
AUTH_ENABLED="false"
