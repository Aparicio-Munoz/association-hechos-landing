# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
Thumbs.db
*.pem

# editores / IDE
.vscode/*
!.vscode/extensions.json
.idea/

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (can opt-in for committing if needed)
.env*
!.env.example

# credenciales descargadas de Google Cloud Console (OAuth) — nunca al repo
client_secret_*.json
"ID cliente"/

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts

# repos separados (viven en su propio remoto, ver memoria del proyecto)
/admin/
/backend/
